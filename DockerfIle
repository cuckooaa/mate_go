# 构建阶段 (使用带 Go 环境的镜像)
FROM golang:1.21-alpine AS builder

# 设置工作目录
WORKDIR /app

# 设置 Go 代理，加速依赖下载
ENV GOPROXY=https://goproxy.cn,direct

# 复制 go.mod 和 go.sum 并下载依赖
COPY go.mod go.sum ./
RUN go mod download

# 复制所有源代码
COPY . .

# 编译 Go 程序为二进制文件 (关闭 CGO 以保证在 Alpine 上的兼容性)
RUN CGO_ENABLED=0 GOOS=linux go build -o mate-app .

# 运行阶段 (使用极简的 alpine 镜像，大幅缩小体积)
FROM alpine:latest

WORKDIR /app

# 安装时区数据，保证日志和数据库时间准确
RUN apk add --no-cache tzdata && \
    cp /usr/share/zoneinfo/Asia/Shanghai /etc/localtime && \
    echo "Asia/Shanghai" > /etc/timezone

# 从构建阶段把编译好的二进制文件复制过来
COPY --from=builder /app/mate-app .

# 将前端模板、静态文件和默认上传目录复制过来
COPY --from=builder /app/templates ./templates
COPY --from=builder /app/static ./static
RUN mkdir -p ./uploads

# 暴露 5000 端口
EXPOSE 5000

# 启动程序
CMD ["./mate-app"]